{
    "PopoverItems": [
        {
            "Title": "$(L,add_suboperation)",
            "OnPress": "/SAPAssetManager/Rules/SubOperations/CreateUpdate/SubOperationCreateNav.js",
            "Visible": false
        },
        {
            "Title": "$(L,add_notification)",
            "Visible": "/ZDSBSSAM/Rules/WorkOrders/Operations/ZCheckOperationNotificationExists.js",
            "OnPress" : "/SAPAssetManager/Rules/Operations/WorkOrderOperationNotificationCreateNav.js"
        },
        {
            "Title" : "$(L,add_part)",
            "OnPress" : "/SAPAssetManager/Rules/Parts/CreateUpdate/PartCreateNav.js",
            "Visible": "/ZDSBSSAM/Rules/Parts/ZPartAddVisibilityFromOpr.js"

        },
        {
            "Title" : "$(L, add_note)",
            "OnPress": "/SAPAssetManager/Rules/Notes/NoteCreateNav.js",
            "Visible": false
        },
        {
            "Title" : "$(L,record_results)",
            "OnPress": "/SAPAssetManager/Rules/InspectionCharacteristics/InspectionCharacteristicsDynamicPageNavWrapper.js",
            "Visible": "/SAPAssetManager/Rules/InspectionCharacteristics/Update/EnableRecordResultsFromOperationDetails.js"
        },
        {
            "Title": "$(L,add_attachment)",
            "OnPress": "/SAPAssetManager/Rules/Documents/Create/DocumentCreateBDSNav.js",
            "Visible": "/SAPAssetManager/Rules/Documents/DocumentAddFromOperationDetails.js"
        },
        {
            "Title": "$(L,add_expense)",
            "OnPress" : "/SAPAssetManager/Rules/Expense/CreateUpdate/ExpenseCreateNav.js",
            "Visible":  "/SAPAssetManager/Rules/Expense/CreateUpdate/IsAllowedExpenseCreate.js"
        },
        {
            "Title": "$(L,add_mileage)",
            "OnPress": "/SAPAssetManager/Rules/ServiceOrders/Mileage/MileageAddNavCheckOnlyUnsavedChanges.js",
            "Visible": "/SAPAssetManager/Rules/ServiceOrders/Mileage/MileageAddIsEnabled.js"
        },
        {
            "Title": "$(L,take_readings)",
            "OnPress": "/SAPAssetManager/Rules/Measurements/Points/MeasuringPointsDataEntryNavWrapper.js",
            "Visible":"/SAPAssetManager/Rules/Measurements/Points/MeasuringPointsTakeReadingsIsVisible.js"
	    },
        {
            "Title": "$(L,generate_service_report)",
            "OnPress": "/SAPAssetManager/Rules/PDF/PDFGenerate.js",
            "Visible": "/SAPAssetManager/Rules/PDF/IsPDFAllowedForOperation.js"
        },
        {
            "Title": "$(L,zAdhoc_issue_part)",
            "OnPress": "/ZDSBSSAM/Actions/Parts/ZPartAdhocIssueCreateChangeset.action",
            "Visible": "/ZDSBSSAM/Rules/Parts/Issue/ZPartAdhocIssueVisible.js"
        },
		{
            "Title": "$(L,zAdhoc_return_part)",
            "OnPress": "/ZDSBSSAM/Actions/Parts/ZPartAdhocReturnCreateChangeset.action",
            "Visible": "/ZDSBSSAM/Rules/Parts/Issue/ZPartAdhocIssueVisible.js"
        }
    ],
    "_Type": "Action.Type.PopoverMenu"
}